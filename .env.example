# PikudAlexa Monitor Configuration

# Your city IDs (comma-separated). Find your city ID using test-cities.js
# Example: Sal'it = 882
MONITOR_CITY_IDS=882

# Optional: Subscribe to entire areas (comma-separated area IDs)
# Example: Sharon = 9
MONITOR_AREA_IDS=

# Enable drill alerts (true/false)
MONITOR_ENABLE_DRILLS=false

# Alexa Event Gateway region (NA, EU, or FE)
ALEXA_REGION=EU

# Alexa Skill credentials (from Amazon Developer Console)
ALEXA_CLIENT_ID=
ALEXA_CLIENT_SECRET=
ALEXA_ACCESS_TOKEN=
ALEXA_REFRESH_TOKEN=

# Voice Monkey (optional - get from https://voicemonkey.io)
VOICE_MONKEY_TOKEN=
VOICE_MONKEY_DEVICE=
